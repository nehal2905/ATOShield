# ──────────────────────────────────────────────────────────────
# ATOShield environment configuration (EXAMPLE — placeholders only)
# Copy to .env and fill real values. NEVER commit the real .env.
# ──────────────────────────────────────────────────────────────

# --- Postgres ---
POSTGRES_USER=atoshield
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=atoshield
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Full async DSN used by SQLAlchemy/asyncpg (derived from the above in compose)
DATABASE_URL=postgresql+asyncpg://atoshield:change_me_postgres@postgres:5432/atoshield

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Auth / JWT ---
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Default analyst bootstrap account (created on first startup if absent)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change_me_admin

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
ML_ARTIFACTS_DIR=/app/ml/artifacts

# Risk tiers / alerting (tunable without code changes)
RISK_MEDIUM_MIN=25
RISK_HIGH_MIN=50
RISK_CRITICAL_MIN=75
ALERT_THRESHOLD=60

# Rate limiting (requests per window)
RATE_LIMIT_EVENTS=60/minute
RATE_LIMIT_SIMULATE=30/minute

# CORS (frontend origin during local dev)
CORS_ORIGINS=http://localhost:5173,http://localhost
